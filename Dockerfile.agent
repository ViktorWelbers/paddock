# Sandbox agent image: Claude Code preinstalled, plus the toolchain a
# developer expects to find (git, node, python3, make, jq).
#
# The sandbox NetworkPolicy only allows egress to the paddock gateway, so
# the base toolchain is baked in here. Dependencies are a different matter:
# agents reach allowlisted registries through the gateway's egress proxy
# (HTTP_PROXY is injected into the sandbox), so `pip install` and friends
# work at runtime when the operator allows the domain. Nonessential agent
# telemetry stays off regardless.
#
# Contract with internal/sandbox: the entrypoint holds the pod alive;
# `paddock attach` execs the agent with a TTY. Numeric USER because the
# kubelet's RunAsNonRoot check rejects named users.
FROM node:22-bookworm-slim

ARG CLAUDE_CODE_VERSION=latest

RUN apt-get update \
 && apt-get install -y --no-install-recommends git ripgrep tini procps ca-certificates \
      python3 python3-pip python3-venv make jq \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} \
 && npm cache clean --force

RUN groupadd -g 10001 agent \
 && useradd -m -u 10001 -g 10001 -d /home/agent agent \
 && mkdir -p /workspace \
 && chown 10001:10001 /workspace

# /workspace is an emptyDir at runtime, and the kubelet creates its mount
# root owned by root (fsGroup only sets the group). Git then refuses to
# touch the developer's repo there -- "detected dubious ownership" -- even
# though every file inside belongs to the agent. The workspace is the
# agent's own by construction, so declare it trusted.
RUN git config --system --add safe.directory /workspace

ENV HOME=/home/agent \
    TERM=xterm-256color \
    DISABLE_AUTOUPDATER=1 \
    DISABLE_TELEMETRY=1 \
    DISABLE_ERROR_REPORTING=1 \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

USER 10001:10001
WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--", "sleep", "infinity"]
