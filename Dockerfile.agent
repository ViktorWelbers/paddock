# Sandbox agent image: Claude Code preinstalled. The sandbox NetworkPolicy
# only allows egress to the paddock gateway, so everything the agent needs
# must be baked in at build time (no runtime npm installs) and all
# nonessential outbound traffic is disabled.
#
# Contract with internal/sandbox: the entrypoint holds the pod alive;
# `paddock attach` execs the agent with a TTY. Numeric USER because the
# kubelet's RunAsNonRoot check rejects named users.
FROM node:22-bookworm-slim

ARG CLAUDE_CODE_VERSION=latest

RUN apt-get update \
 && apt-get install -y --no-install-recommends git ripgrep tini procps ca-certificates \
      python3 python3-pip python3-venv make jq \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g @anthropic-ai/claude-code@${CLAUDE_CODE_VERSION} \
 && npm cache clean --force

RUN groupadd -g 10001 agent \
 && useradd -m -u 10001 -g 10001 -d /home/agent agent \
 && mkdir -p /workspace \
 && chown 10001:10001 /workspace

ENV HOME=/home/agent \
    TERM=xterm-256color \
    DISABLE_AUTOUPDATER=1 \
    DISABLE_TELEMETRY=1 \
    DISABLE_ERROR_REPORTING=1 \
    CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1

USER 10001:10001
WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--", "sleep", "infinity"]
