# Sandbox agent image: the pi coding agent against an OpenAI-compatible
# upstream (vLLM, llama.cpp, ...) through the paddock gateway. Same contract
# as Dockerfile.agent: the entrypoint holds the pod alive, `paddock attach`
# execs `pi` with a TTY, everything is baked in at build time because the
# NetworkPolicy blocks all egress except the gateway.
#
# pi itself is installed under /opt/pi; `pi` on PATH is a launcher that
# renders ~/.pi/agent/models.json from the sandbox env (models.json cannot
# interpolate env vars into baseUrl) before exec'ing the real binary.
FROM node:22-bookworm-slim

ARG PI_VERSION=latest

RUN apt-get update \
 && apt-get install -y --no-install-recommends git ripgrep tini procps ca-certificates \
      python3 python3-pip python3-venv make jq \
 && rm -rf /var/lib/apt/lists/* \
 && npm install -g --prefix /opt/pi @earendil-works/pi-coding-agent@${PI_VERSION} \
 && npm cache clean --force

COPY scripts/agent-pi-launcher.sh /usr/local/bin/pi
RUN chmod 755 /usr/local/bin/pi

RUN groupadd -g 10001 agent \
 && useradd -m -u 10001 -g 10001 -d /home/agent agent \
 && mkdir -p /workspace \
 && chown 10001:10001 /workspace

# /workspace is an emptyDir at runtime, and the kubelet creates its mount
# root owned by root (fsGroup only sets the group). Git then refuses to
# touch the developer's repo there -- "detected dubious ownership" -- even
# though every file inside belongs to the agent. The workspace is the
# agent's own by construction, so declare it trusted.
RUN git config --system --add safe.directory /workspace

# PI_OFFLINE: no update checks or other startup network calls — they can
# only hang against the sandbox NetworkPolicy.
ENV HOME=/home/agent \
    TERM=xterm-256color \
    PI_OFFLINE=1

USER 10001:10001
WORKDIR /workspace

ENTRYPOINT ["/usr/bin/tini", "--", "sleep", "infinity"]
